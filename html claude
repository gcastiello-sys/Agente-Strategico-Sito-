<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Agente Strategico — Brand Kit + Hero Reference</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* ============================================
   AGENTE STRATEGICO — DESIGN TOKENS
   ============================================ */
:root {
  /* Backgrounds */
  --bg-deep: #0B0614;
  --bg-void: #140A23;
  --bg-card: rgba(20, 10, 35, 0.6);

  /* Neon Core */
  --neon-blue: #2C5DFF;
  --neon-violet: #7B2CFF;
  --neon-magenta: #FF2BD6;
  --neon-cyan: #19D3FF;

  /* Text */
  --text-primary: #F5F2FF;
  --text-muted: #B9A8D6;
  --border: #2A1D3E;

  /* Buttons */
  --btn-primary: #2C5DFF;
  --btn-primary-hover: #3C76FF;
  --btn-secondary: #7B2CFF;
  --btn-secondary-hover: #8E4BFF;

  /* Gradients */
  --grad-hero: linear-gradient(135deg, #2C5DFF 0%, #7B2CFF 50%, #FF2BD6 100%);
  --grad-blue-cyan: linear-gradient(135deg, #2C5DFF 0%, #19D3FF 50%, #7B2CFF 100%);

  /* Typography */
  --font-display: 'Syne', sans-serif;
  --font-body: 'DM Sans', sans-serif;

  /* Spacing */
  --space-xs: 8px;
  --space-sm: 16px;
  --space-md: 24px;
  --space-lg: 48px;
  --space-xl: 80px;
  --space-2xl: 128px;

  /* Radius */
  --radius-sm: 6px;
  --radius-md: 12px;
  --radius-lg: 20px;
  --radius-pill: 999px;
}

/* ============================================
   RESET & BASE
   ============================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--bg-deep);
  color: var(--text-primary);
  font-family: var(--font-body);
  font-size: 16px;
  line-height: 1.6;
  overflow-x: hidden;
}

/* ============================================
   BRAND KIT PANEL (TOP)
   ============================================ */
.brand-kit {
  background: var(--bg-void);
  border-bottom: 1px solid var(--border);
  padding: var(--space-lg) var(--space-lg);
}

.brand-kit-header {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--neon-cyan);
  margin-bottom: var(--space-lg);
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.brand-kit-header::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

.kit-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: var(--space-md);
}

.kit-section-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: var(--space-sm);
}

/* Color swatches */
.swatches {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.swatch-row {
  display: flex;
  gap: 8px;
  align-items: center;
}

.swatch {
  width: 40px;
  height: 40px;
  border-radius: var(--radius-sm);
  border: 1px solid rgba(255,255,255,0.08);
  flex-shrink: 0;
  position: relative;
}

.swatch.glow-blue { background: var(--neon-blue); box-shadow: 0 0 16px rgba(44,93,255,0.5); }
.swatch.glow-violet { background: var(--neon-violet); box-shadow: 0 0 16px rgba(123,44,255,0.5); }
.swatch.glow-magenta { background: var(--neon-magenta); box-shadow: 0 0 16px rgba(255,43,214,0.5); }
.swatch.glow-cyan { background: var(--neon-cyan); box-shadow: 0 0 16px rgba(25,211,255,0.5); }
.swatch.bg-deep { background: #0B0614; }
.swatch.bg-void { background: #140A23; }

.swatch-info { line-height: 1.3; }
.swatch-name { font-size: 12px; font-weight: 500; color: var(--text-primary); }
.swatch-hex { font-size: 11px; color: var(--text-muted); font-family: monospace; }

/* Gradients */
.grad-chips {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.grad-chip {
  height: 48px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  padding: 0 var(--space-sm);
  font-size: 11px;
  font-weight: 600;
  color: white;
  letter-spacing: 0.5px;
}

.grad-chip.g1 { background: linear-gradient(135deg, #2C5DFF, #7B2CFF, #FF2BD6); }
.grad-chip.g2 { background: linear-gradient(135deg, #2C5DFF, #19D3FF, #7B2CFF); }
.grad-chip.g3 { background: linear-gradient(135deg, #7B2CFF, #FF2BD6, #19D3FF); }

/* Typography */
.type-stack { display: flex; flex-direction: column; gap: 12px; }

.type-specimen {
  padding: 12px 16px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
}

.type-specimen .label { font-size: 10px; color: var(--text-muted); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }

/* Buttons kit */
.btn-kit { display: flex; flex-direction: column; gap: 10px; }

.btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 14px 28px;
  border-radius: var(--radius-md);
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.5px;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: all 0.2s ease;
  width: fit-content;
}

.btn-primary {
  background: var(--btn-primary);
  color: white;
  box-shadow: 0 0 24px rgba(44,93,255,0.35), 0 4px 12px rgba(0,0,0,0.4);
}

.btn-primary:hover {
  background: var(--btn-primary-hover);
  box-shadow: 0 0 36px rgba(44,93,255,0.55), 0 4px 16px rgba(0,0,0,0.4);
  transform: translateY(-1px);
}

.btn-secondary {
  background: transparent;
  color: var(--neon-violet);
  border: 1.5px solid var(--neon-violet);
  box-shadow: 0 0 16px rgba(123,44,255,0.15);
}

.btn-secondary:hover {
  background: rgba(123,44,255,0.12);
  box-shadow: 0 0 28px rgba(123,44,255,0.35);
  transform: translateY(-1px);
}

.btn-ghost {
  background: rgba(255,255,255,0.05);
  color: var(--text-muted);
  border: 1px solid var(--border);
}

.btn-ghost:hover {
  background: rgba(255,255,255,0.08);
  color: var(--text-primary);
}

.btn-arrow::after { content: '→'; font-size: 16px; }

/* ============================================
   NAVBAR — DARK GLASS VERSION
   ============================================ */
.navbar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(11, 6, 20, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  padding: 0 var(--space-lg);
  height: 72px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-logo {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 800;
  color: var(--text-primary);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 10px;
}

.logo-mark {
  width: 36px;
  height: 36px;
  background: var(--grad-hero);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 900;
  box-shadow: 0 0 20px rgba(123,44,255,0.4);
}

.nav-links {
  display: flex;
  align-items: center;
  gap: var(--space-lg);
  list-style: none;
}

.nav-links a {
  color: var(--text-muted);
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
  transition: color 0.2s;
  position: relative;
}

.nav-links a:hover { color: var(--text-primary); }

.nav-links a.active {
  color: var(--text-primary);
}

.nav-links a.active::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--grad-hero);
  border-radius: 2px;
}

.nav-cta-group {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.nav-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 12px;
  background: rgba(255,43,214,0.12);
  border: 1px solid rgba(255,43,214,0.3);
  border-radius: var(--radius-pill);
  font-size: 11px;
  font-weight: 700;
  color: var(--neon-magenta);
  letter-spacing: 0.5px;
}

.nav-badge::before {
  content: '';
  width: 6px;
  height: 6px;
  background: var(--neon-magenta);
  border-radius: 50%;
  box-shadow: 0 0 8px var(--neon-magenta);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.2); }
}

/* ============================================
   HERO SECTION
   ============================================ */
.hero {
  position: relative;
  min-height: 92vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: var(--space-xl) var(--space-lg);
  overflow: hidden;
}

/* Background glow orbs */
.hero-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  opacity: 0.18;
}

.orb-1 {
  width: 600px; height: 600px;
  background: var(--neon-blue);
  top: -200px; left: -150px;
}

.orb-2 {
  width: 500px; height: 500px;
  background: var(--neon-violet);
  bottom: -100px; right: 10%;
}

.orb-3 {
  width: 300px; height: 300px;
  background: var(--neon-magenta);
  top: 30%; right: 25%;
  opacity: 0.1;
}

/* Grid overlay */
.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(44,93,255,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(44,93,255,0.04) 1px, transparent 1px);
  background-size: 60px 60px;
  pointer-events: none;
}

.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
}

/* Eyebrow */
.eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 8px 18px;
  background: rgba(44,93,255,0.1);
  border: 1px solid rgba(44,93,255,0.25);
  border-radius: var(--radius-pill);
  font-size: 12px;
  font-weight: 700;
  color: var(--neon-cyan);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: var(--space-md);
  animation: fadeInDown 0.6s ease both;
}

.eyebrow-line {
  width: 20px;
  height: 1px;
  background: var(--neon-cyan);
  box-shadow: 0 0 8px var(--neon-cyan);
}

/* Hero headline */
.hero-h1 {
  font-family: var(--font-display);
  font-size: clamp(44px, 6vw, 80px);
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: -1.5px;
  color: var(--text-primary);
  margin-bottom: var(--space-md);
  animation: fadeInUp 0.7s 0.1s ease both;
  max-width: 800px;
}

.hero-h1 .grad-text {
  background: var(--grad-hero);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-h1 .outline-text {
  -webkit-text-stroke: 2px rgba(123,44,255,0.6);
  color: transparent;
}

.hero-sub {
  font-size: clamp(16px, 2vw, 20px);
  color: var(--text-muted);
  line-height: 1.7;
  max-width: 560px;
  margin-bottom: var(--space-lg);
  animation: fadeInUp 0.7s 0.2s ease both;
  font-weight: 300;
}

.hero-sub strong { color: var(--text-primary); font-weight: 500; }

/* CTA group */
.hero-cta {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex-wrap: wrap;
  animation: fadeInUp 0.7s 0.3s ease both;
  margin-bottom: var(--space-xl);
}

.btn-hero-primary {
  padding: 18px 36px;
  background: var(--neon-blue);
  color: white;
  border-radius: var(--radius-md);
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 700;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  box-shadow: 0 0 40px rgba(44,93,255,0.4), 0 8px 24px rgba(0,0,0,0.5);
  transition: all 0.25s ease;
  border: none;
  cursor: pointer;
  position: relative;
  overflow: hidden;
}

.btn-hero-primary::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.1), transparent);
}

.btn-hero-primary:hover {
  background: var(--btn-primary-hover);
  box-shadow: 0 0 60px rgba(44,93,255,0.6), 0 8px 32px rgba(0,0,0,0.5);
  transform: translateY(-2px);
}

.btn-hero-secondary {
  padding: 17px 28px;
  background: transparent;
  color: var(--text-muted);
  border-radius: var(--radius-md);
  font-family: var(--font-display);
  font-size: 15px;
  font-weight: 600;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: 1px solid var(--border);
  transition: all 0.25s ease;
  cursor: pointer;
}

.btn-hero-secondary:hover {
  border-color: rgba(123,44,255,0.4);
  color: var(--text-primary);
  background: rgba(123,44,255,0.08);
}

/* FOMO line */
.fomo-line {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--text-muted);
  animation: fadeInUp 0.7s 0.35s ease both;
}

.fomo-dot {
  width: 8px;
  height: 8px;
  background: var(--neon-magenta);
  border-radius: 50%;
  box-shadow: 0 0 10px var(--neon-magenta);
  animation: pulse 2s infinite;
  flex-shrink: 0;
}

.fomo-line strong { color: var(--neon-magenta); font-weight: 600; }

/* ============================================
   PROOF BAR
   ============================================ */
.proof-bar {
  background: rgba(20, 10, 35, 0.8);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  backdrop-filter: blur(20px);
  padding: var(--space-md) var(--space-lg);
  animation: fadeInUp 0.7s 0.4s ease both;
}

.proof-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-md);
  align-items: center;
}

.proof-divider {
  width: 1px;
  height: 100%;
  background: var(--border);
}

.proof-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: var(--space-sm);
  position: relative;
}

.proof-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 10%;
  height: 80%;
  width: 1px;
  background: var(--border);
}

.proof-number {
  font-family: var(--font-display);
  font-size: 36px;
  font-weight: 800;
  line-height: 1;
  background: var(--grad-hero);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 4px;
}

.proof-label {
  font-size: 12px;
  color: var(--text-muted);
  font-weight: 400;
  line-height: 1.4;
}

.proof-placeholder {
  opacity: 0.4;
  font-style: italic;
}

/* ============================================
   ROUTER SECTION (4 card)
   ============================================ */
.router-section {
  padding: var(--space-xl) var(--space-lg);
  max-width: 1200px;
  margin: 0 auto;
}

.section-tag {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--neon-violet);
  margin-bottom: var(--space-sm);
}

.section-tag::before {
  content: '';
  width: 24px;
  height: 2px;
  background: var(--neon-violet);
  box-shadow: 0 0 8px var(--neon-violet);
}

.section-title {
  font-family: var(--font-display);
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.5px;
  color: var(--text-primary);
  margin-bottom: var(--space-sm);
}

.section-sub {
  font-size: 17px;
  color: var(--text-muted);
  margin-bottom: var(--space-lg);
  max-width: 480px;
  font-weight: 300;
}

.router-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-sm);
}

.router-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-lg) var(--space-md);
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.router-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--card-accent, rgba(44,93,255,0.06)), transparent 60%);
  opacity: 0;
  transition: opacity 0.3s;
}

.router-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--card-line, var(--neon-blue));
  opacity: 0;
  transition: opacity 0.3s;
  box-shadow: 0 0 12px var(--card-line, var(--neon-blue));
}

.router-card:hover {
  border-color: var(--card-line, var(--neon-blue));
  transform: translateY(-4px);
  box-shadow: 0 20px 60px rgba(0,0,0,0.4);
}

.router-card:hover::before,
.router-card:hover::after { opacity: 1; }

.router-card.c1 { --card-accent: rgba(44,93,255,0.08); --card-line: var(--neon-blue); }
.router-card.c2 { --card-accent: rgba(123,44,255,0.08); --card-line: var(--neon-violet); }
.router-card.c3 { --card-accent: rgba(255,43,214,0.06); --card-line: var(--neon-magenta); }
.router-card.c4 { --card-accent: rgba(25,211,255,0.06); --card-line: var(--neon-cyan); }

.card-eyebrow {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--card-line);
  display: flex;
  align-items: center;
  gap: 8px;
}

.card-eyebrow::before {
  content: '';
  width: 16px;
  height: 1.5px;
  background: var(--card-line);
  box-shadow: 0 0 6px var(--card-line);
}

.card-title {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.card-desc {
  font-size: 14px;
  color: var(--text-muted);
  line-height: 1.6;
  font-weight: 300;
}

.card-cta {
  margin-top: auto;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 700;
  color: var(--card-line);
  font-family: var(--font-display);
  transition: gap 0.2s;
}

.router-card:hover .card-cta { gap: 10px; }

/* ============================================
   ECOSYSTEM STRIP
   ============================================ */
.ecosystem-strip {
  padding: var(--space-xl) var(--space-lg);
  background: var(--bg-void);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.eco-inner {
  max-width: 1200px;
  margin: 0 auto;
}

.eco-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: var(--space-lg);
  flex-wrap: wrap;
  gap: var(--space-md);
}

.eco-steps {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 4px;
  position: relative;
}

.eco-steps::before {
  content: '';
  position: absolute;
  top: 24px;
  left: calc(10% + 24px);
  right: calc(10% + 24px);
  height: 1px;
  background: linear-gradient(90deg, var(--neon-blue), var(--neon-violet), var(--neon-magenta), var(--neon-cyan));
  opacity: 0.3;
  z-index: 0;
}

.eco-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: var(--space-md) var(--space-sm);
  position: relative;
  z-index: 1;
}

.step-icon {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 800;
  margin-bottom: var(--space-sm);
  border: 1px solid rgba(255,255,255,0.08);
  background: rgba(255,255,255,0.03);
  color: var(--step-color);
  box-shadow: 0 0 20px rgba(44,93,255,0.15);
}

.eco-step:nth-child(1) .step-icon { --step-color: var(--neon-blue); border-color: rgba(44,93,255,0.3); }
.eco-step:nth-child(2) .step-icon { --step-color: var(--neon-violet); border-color: rgba(123,44,255,0.3); }
.eco-step:nth-child(3) .step-icon { --step-color: var(--neon-magenta); border-color: rgba(255,43,214,0.3); }
.eco-step:nth-child(4) .step-icon { --step-color: var(--neon-cyan); border-color: rgba(25,211,255,0.3); }
.eco-step:nth-child(5) .step-icon { --step-color: #FFD700; border-color: rgba(255,215,0,0.3); }

.step-name {
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 700;
  color: var(--step-color, var(--text-primary));
  margin-bottom: 4px;
}

.step-desc {
  font-size: 11px;
  color: var(--text-muted);
  line-height: 1.5;
}

/* ============================================
   TESTIMONIAL STRIP
   ============================================ */
.testi-section {
  padding: var(--space-xl) var(--space-lg);
  max-width: 1200px;
  margin: 0 auto;
}

.testi-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-sm);
}

.testi-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  position: relative;
  overflow: hidden;
}

.testi-card::before {
  content: '"';
  position: absolute;
  top: -20px;
  right: 20px;
  font-family: var(--font-display);
  font-size: 120px;
  font-weight: 900;
  color: rgba(123,44,255,0.06);
  line-height: 1;
  pointer-events: none;
}

.testi-quote {
  font-size: 15px;
  color: var(--text-primary);
  line-height: 1.7;
  margin-bottom: var(--space-md);
  font-weight: 300;
}

.testi-quote strong { color: var(--neon-cyan); font-weight: 500; }

.testi-author {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.testi-avatar {
  width: 44px;
  height: 44px;
  border-radius: var(--radius-sm);
  background: linear-gradient(135deg, var(--neon-blue), var(--neon-violet));
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 14px;
  color: white;
  flex-shrink: 0;
}

.testi-meta { line-height: 1.3; }
.testi-name { font-size: 14px; font-weight: 600; color: var(--text-primary); }
.testi-role { font-size: 12px; color: var(--text-muted); }
.testi-result {
  margin-top: 4px;
  font-size: 11px;
  font-weight: 700;
  color: var(--neon-magenta);
  display: flex;
  align-items: center;
  gap: 4px;
}

/* ============================================
   FINAL CTA SECTION
   ============================================ */
.final-cta {
  padding: var(--space-xl) var(--space-lg);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.final-cta-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(44,93,255,0.06), rgba(123,44,255,0.08), rgba(255,43,214,0.05));
  pointer-events: none;
}

.final-cta-border {
  position: absolute;
  inset: var(--space-md);
  border: 1px solid rgba(123,44,255,0.2);
  border-radius: var(--radius-lg);
  pointer-events: none;
}

.final-cta-inner {
